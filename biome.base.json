{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},

	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"useExhaustiveDependencies": "error",
				"noConstAssign": "error",
				"noUndeclaredVariables": "error",
				"noVoidTypeReturn": "error"
			},
			"suspicious": {
				"noConsole": "warn",
				"noDebugger": "error",
				"noDoubleEquals": "error",
				"noExplicitAny": "warn",
				"noArrayIndexKey": "warn",
				"noConfusingVoidType": "error"
			},
			"style": {
				"useConst": "error",
				"useSingleVarDeclarator": "error",
				"noNegationElse": "warn",
				"useSelfClosingElements": "error",
				"noUselessElse": "warn"
			},
			"complexity": {
				"noExtraBooleanCast": "error",
				"noUselessCatch": "error",
				"noUselessConstructor": "error",
				"useSimplifiedLogicExpression": "warn"
			},
			"performance": { "recommended": true }
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["**/routeTree.gen.ts"],
			"linter": {
				"enabled": false
			},
			"formatter": {
				"enabled": false
			}
		}
	]
}
